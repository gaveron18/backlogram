# Copy this file to .env.local and fill in your Integram credentials.
# These are used by the blog admin panel to read/write articles via the Integram API.

# Base URL of your Integram instance (no trailing slash)
VITE_INTEGRAM_API_URL=https://integram.io

# Access token for the Integram workspace (found in workspace settings)
VITE_INTEGRAM_TOKEN=your_access_token_here

# ID of the Integram table that stores blog articles
VITE_INTEGRAM_TABLE_ID=your_table_id_here
